# Shoutrrr notification URL — see https://containrrr.dev/shoutrrr/services/overview/
# Examples:
#   telegram://token@telegram?chats=channel-id
#   discord://token@webhookid
#   slack://token-a/token-b/token-c
#   gotify://hostname/token
SHOUTRRR_URL=

# Your location (center point)
LATITUDE=24.8539174
LONGITUDE=46.7484485

# Search radius in kilometers
RADIUS_KM=10

# Seconds between flight checks
QUERY_DELAY=30

# Airport runway monitoring (optional)
# Get notified when the active runway changes direction
# ICAO code (e.g. OERK for Riyadh) — used for METAR/TAF weather data
AIRPORT_ICAO=OERK
# IATA code (e.g. RUH) — used in notification display
AIRPORT_CODE=RUH
# Comma-separated runway magnetic headings (e.g. RUH has 33/15 → 330,150)
RUNWAY_HEADINGS=330,150
