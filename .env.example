# Shoutrrr notification URL — see https://containrrr.dev/shoutrrr/services/overview/
# Examples:
#   telegram://token@telegram?chats=channel-id
#   discord://token@webhookid
#   slack://token-a/token-b/token-c
#   gotify://hostname/token
SHOUTRRR_URL=

# Your location (center point)
LATITUDE=24.8539174
LONGITUDE=46.7484485

# Search radius in kilometers
RADIUS_KM=10

# Seconds between flight checks
QUERY_DELAY=30

# Airport runway monitoring (optional)
# Just set the IATA code — ICAO and runway headings are auto-detected
AIRPORT_CODE=RUH

# Telegram bot token for commands (optional, falls back to SHOUTRRR_URL token)
BOT_TOKEN=

# Telegram user ID to restrict bot commands (optional, leave empty for no restriction)
BOT_ADMIN_ID=
